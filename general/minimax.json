{
  "name": "minimax",
  "description": "MiniMax provides high-performance text models for agentic coding, productivity, and long-context chat workloads.",
  "default": {
    "params": [
      { "key": "max_tokens", "defaultValue": 1024, "minValue": 1, "maxValue": 204800 },
      { "key": "temperature", "defaultValue": 1, "minValue": 0, "maxValue": 2 },
      { "key": "stop", "defaultValue": null, "type": "array-of-strings", "skipValues": [null, []] },
      { "key": "top_p", "defaultValue": 1, "minValue": 0, "maxValue": 1 },
      { "key": "n", "defaultValue": 1, "minValue": 1, "maxValue": 10 },
      { "key": "frequency_penalty", "defaultValue": 0, "minValue": -2, "maxValue": 2 },
      { "key": "presence_penalty", "defaultValue": 0, "minValue": -2, "maxValue": 2 },
      { "key": "stream", "defaultValue": true, "type": "boolean" },
      {
        "key": "tool_choice",
        "type": "non-view-manage-data",
        "defaultValue": null,
        "options": [
          { "value": "none", "name": "None" },
          { "value": "auto", "name": "Auto" },
          { "value": "required", "name": "Required" },
          {
            "value": "custom",
            "name": "Custom",
            "schema": {
              "type": "json"
            }
          }
        ],
        "skipValues": [null, []],
        "rule": {
          "default": {
            "condition": "tools",
            "then": "auto",
            "else": null
          }
        }
      },
      {
        "key": "response_format",
        "defaultValue": null,
        "options": [
          {
            "value": null,
            "name": "Text"
          },
          {
            "value": { "type": "json_object" },
            "name": "JSON"
          }
        ],
        "skipValues": [null]
      }
    ],
    "messages": { "options": ["system", "user", "assistant", "developer", "tool"] },
    "type": { "primary": "chat", "supported": ["tools"] }
  },
  "MiniMax-M2.7": {
    "params": [{ "key": "max_tokens", "maxValue": 204800 }],
    "type": { "primary": "chat", "supported": ["tools"] }
  },
  "MiniMax-M2.7-highspeed": {
    "params": [{ "key": "max_tokens", "maxValue": 204800 }],
    "type": { "primary": "chat", "supported": ["tools"] }
  }
}
